{
  "name": "lobosmatch",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "electron:dev": "set ELECTRON_DEV=1 && npx electron electron/main.js",
    "electron:build": "npm run build:web && npx electron-builder --win --config electron-builder.json",
    "desktop": "npx electron electron/main.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.10",
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "axios": "^1.15.2",
    "expo": "~54.0.33",
    "expo-image-picker": "^55.0.19",
    "expo-location": "^55.1.8",
    "expo-secure-store": "^55.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-web": "^0.21.2",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
  },
  "private": true,
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
